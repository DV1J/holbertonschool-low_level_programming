#include "main.h"
#include <stdlib.h>

/**
 * alloc_grid - returns a pointer to a 2 dimensional array of integers.
 * @width: width
 * @height: height
 * Return: 0 || array
 */
int **alloc_grid(int width, int height)
{
    int col, row;
    int **array;

    if (width <= 0 || height <= 0)
    {
        return (0);
    }
    
    /* FIX: Changed to sizeof(int *) */
    array = malloc(height * sizeof(int *));
    if (array == 0)
    {
        return (0);
    }
    
    array[0] = malloc(width * height * sizeof(int));
    if (array[0] == 0)
    {
        free(array); /* FIX: Removed double free */
        return (0);
    }
    
    for (row = 1; row < height; row++)
    {
        array[row] = array[0] + (row * width);
    }
    
    for (row = 0; row < height; row++)
    {
        col = 0; /* FIX: Reset col to 0 for every row */
        while (col < width)
        {
            array[row][col] = 0;
            col++;
        }
    }
    
    return (array);
    /* FIX: Removed unreachable free(array) */
}

